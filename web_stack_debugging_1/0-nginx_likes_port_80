#!/usr/bin/env bash
# This script ensures Nginx is installed, configured for port 80, and running.

# 1. Install Nginx if it's not present (the -y flag answers 'yes' automatically)
apt-get update
apt-get install -y nginx

# 2. Set the listen port to 80 (replacing any existing listen directive)
# This uses a regex to find any 'listen' line and force it to 'listen 80 default_server;'
sed -i 's/listen [0-9]\+.*/listen 80 default_server;/g' /etc/nginx/sites-enabled/default

# 3. Restart the service to apply changes
service nginx restart
