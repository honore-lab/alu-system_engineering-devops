#!/usr/bin/env bash
# Configures a custom 404 error page containing 'Ceci n'est pas une page'

apt-get update -y
apt-get install nginx -y

# Create custom 404 page content
echo "Ceci n'est pas une page" > /var/www/html/custom_404.html

# Update Nginx configuration to point to custom 404 error page
sed -i "/listen 80 default_server;/a \    error_page 404 /custom_404.html;\n    location = /custom_404.html {\n        internal;\n    }" /etc/nginx/sites-available/default

/etc/init.d/nginx restart
