#!/usr/bin/env bash
# Transfers a file from client to server using scp

# Check for exactly 4 parameters
if [ "$#" -ne 4 ]; then
    echo "Usage: 0-transfer_file PATH_TO_FILE IP USERNAME PATH_TO_SSH_KEY"
    exit 1
fi

# Variables for clarity
FILE_PATH=$1
SERVER_IP=$2
USER_NAME=$3
SSH_KEY=$4

# Execute the transfer
# We use -o BatchMode=yes to ensure it doesn't hang on prompts
# We use -o StrictHostKeyChecking=no to bypass key verification
scp -o BatchMode=yes -o StrictHostKeyChecking=no -i "$SSH_KEY" "$FILE_PATH" "$USER_NAME@$SERVER_IP":~/
