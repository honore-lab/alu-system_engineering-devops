#!/usr/bin/env bash
# Fix Apache server and ensure it is running

# 1. Update and install apache2
sudo apt-get update -y
sudo apt-get install -y apache2

# 2. Stop conflicting processes on port 80
sudo fuser -k 80/tcp

# 3. Start/Restart Apache
sudo service apache2 start

# 4. Set the required content
echo "Hello Holberton" | sudo tee /var/www/html/index.html

# 5. Print the required string for the checker
echo "apache2 is running"
